<Window x:Class="C01UseDelegateCommand.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:crystal="http://schemas.crystal.com/0.9"
        crystal:ViewModelLocator.AutoWireViewModel="True"
        Title="ICommand" Height="350" Width="525">
  <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
    <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}" Content="Can Execute Command" Margin="10"/>
    <Button Command="{Binding MyCommand}" Content="My Awesome Command" Margin="10"/>
    <TextBlock Text="{Binding UpdateText}" Margin="10" FontSize="22"/>
  </StackPanel>
</Window>
