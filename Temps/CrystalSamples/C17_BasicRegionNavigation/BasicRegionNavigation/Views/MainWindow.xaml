<Window x:Class="BasicRegionNavigation.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:crystal="http://schemas.crystal.com/0.9"
        xmlns:local="clr-namespace:BasicRegionNavigation"
        crystal:ViewModelLocator.AutoWireViewModel="True"
        Title="Region Navigation" Height="350" Width="525">
  <DockPanel LastChildFill="True">
    <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="5" >
      <Button Command="{Binding NavigateCommand}" CommandParameter="ViewA" Margin="5" Content="Navigate to View A"/>
      <Button Command="{Binding NavigateCommand}" CommandParameter="ViewB" Margin="5" Content="Navigate to View B"/>
    </StackPanel>
    <ContentControl crystal:RegionManager.RegionName="{x:Static local:RegionNames.MainContentRegionName}" Margin="5"/>
  </DockPanel>
</Window>
