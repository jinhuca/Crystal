<Window x:Class="UsingEventAggregator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:crystal="http://schemas.crystal.com/0.9"
        crystal:ViewModelLocator.AutoWireViewModel="True"
        Title="{Binding Title}" Height="350" Width="525">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition/>
      <ColumnDefinition/>
    </Grid.ColumnDefinitions>
    <ContentControl crystal:RegionManager.RegionName="LeftRegion"/>
    <ContentControl crystal:RegionManager.RegionName="RightRegion" Grid.Column="1"/>
  </Grid>
</Window>
